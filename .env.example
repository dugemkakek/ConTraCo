# Confluence Trading Consultant — environment config
# Copy this file, rename to .env, and fill in your values.

# JWT secret for auth tokens (generate a unique one)
JWT_SECRET=change-me-to-a-random-secret-string

# Admin seed credentials (first-run only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# CEX API (optional — public endpoints work without these)
GATEIO_API_KEY=
GATEIO_API_SECRET=

# LLM Inference Provider
# Set one of these to enable the AI council (default: stub)
LLM_API_KEY=
INFERHUB_API_KEY=

# LLM context compression threshold (tokens)
LLM_CONTEXT_COMPRESS_AT_TOKENS=100000

# Market data provider (default: binance — real public data, no key required)
# Options: binance | gateio | bybit | okx | kraken | mock
MARKET_DATA_PROVIDER=binance

# Database (default: SQLite)
DATABASE_URL=sqlite:///./dev.db

# --------- Free data source keys (all optional; default behaviour is free tier) ----

# FRED macro (rates, CPI, GDP)
# FRED_API_KEY=

# Finnhub (real-time-ish quotes, calendar, news)
# FINNHUB_API_KEY=

# Etherscan on-chain (free tier; for whale/flow gate)
# ETHERSCAN_API_KEY=

# The Graph host API (improves Uniswap v3 rate limits)
# GRAPH_API_KEY=
