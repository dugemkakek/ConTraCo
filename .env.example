# Confluence Trading Consultant — environment config
# Copy this file, rename to .env, and fill in your values.

# JWT secret for auth tokens (generate a unique one)
JWT_SECRET=change-me-to-a-random-secret-string

# Admin seed credentials (first-run only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Gate.io API (optional — mock provider works without these)
GATEIO_API_KEY=
GATEIO_API_SECRET=

# LLM Inference Provider
# Set one of these to enable the AI council (default: stub)
LLM_API_KEY=
INFERHUB_API_KEY=

# LLM context compression threshold (tokens)
LLM_CONTEXT_COMPRESS_AT_TOKENS=100000

# Market data provider (mock | gateio)
MARKET_DATA_PROVIDER=mock

# Database (default: SQLite)
DATABASE_URL=sqlite:///./dev.db
